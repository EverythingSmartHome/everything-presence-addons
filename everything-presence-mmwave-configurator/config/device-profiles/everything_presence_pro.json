    "upsideDownMounting": {
      "template": "switch.${name}_upside_down_mounting",
      "category": "setting",
      "group": "Tracking Radar",
      "label": "Upside Down Mounting",
      "controlType": "switch",
      "description": "Enable if the device is mounted upside down.",
      "required": false
