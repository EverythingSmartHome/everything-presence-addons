{
  "id": "everything_presence_pro",
  "schemaVersion": "1.3",
  "label": "Everything Presence Pro",
  "model": "Everything Presence Pro",
  "manufacturer": "EverythingSmartTechnology",
  "iconUrl": "./icons/devices/everything_presence_pro.png",
  "iconUrlCeiling": "./icons/devices/everything_presence_pro_ceiling.png",
  "coverage": {
    "presets": {
      "ld2450": { "label": "LD2450", "horizontalFovDeg": 120, "verticalFovDeg": 70, "maxRangeMeters": 6 },
      "sen0609": { "label": "SEN0609", "horizontalFovDeg": 100, "verticalFovDeg": 40, "maxRangeMeters": 25 }
    },
    "secondarySensors": {
      "pir": { "label": "PIR", "horizontalFovDeg": 102, "verticalFovDeg": 92, "maxRangeMeters": 12 }
    },
    "defaultPresetId": "ld2450"
  },
  "capabilities": {
    "tracking": true,
    "zones": true,
    "exclusionZones": true,
    "entryZones": false,
    "polygonZones": true,
    "distanceOnlyTracking": false,
    "sensors": {
      "mmwavePresence": true,
      "pir": false,
      "light": false,
      "temperature": false
    }
  },
  "limits": {
    "maxZones": 4,
    "maxExclusionZones": 2,
    "maxEntryZones": 0,
    "maxTargets": 3,
    "maxRangeMeters": 6,
    "fieldOfViewDegrees": 120
  },
  "services": {
    "getBuildFlags": {
      "domain": "esphome",
      "template": "${name}_get_build_flags"
    },
    "setUpdateManifest": {
      "domain": "esphome",
      "template": "${name}_set_update_manifest"
    }
  },
  "entities": {
    "presence": {
      "template": "binary_sensor.${name}_occupancy",
      "category": "sensor",
      "subcategory": "presence",
      "label": "Occupancy",
      "required": true
    },
    "co2": {
      "template": "sensor.${name}_co2",
      "category": "sensor",
      "subcategory": "environment",
      "label": "CO2",
      "required": false
    },
    "firmwareUpdate": {
      "template": "update.${name}_firmware_update",
      "category": "sensor",
      "subcategory": "firmware",
      "label": "Firmware Update",
      "required": false
    },
    "maxDistance": {
      "template": "number.${name}_tracking_detection_range",
      "category": "setting",
      "group": "Tracking Radar",
      "label": "Tracking Detection Range",
      "controlType": "number",
      "min": 0,
      "max": 600,
      "step": 1,
      "unit": "cm",
      "required": true
    },
    "occupancyOffDelay": {
      "template": "number.${name}_tracking_presence_timeout",
      "category": "setting",
      "group": "Tracking Radar",
      "label": "Tracking Presence Timeout",
      "controlType": "number",
      "min": 0,
      "max": 600,
      "step": 1,
      "unit": "s",
      "required": true
