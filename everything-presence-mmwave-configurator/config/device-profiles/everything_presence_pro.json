    "installationAngle": {
      "template": "number.${name}_tracking_sensor_angle",
      "category": "setting",
      "group": "Tracking Radar",
      "label": "Tracking Sensor Angle",
      "controlType": "number",
      "min": -45,
      "max": 45,
      "step": 1,
      "unit": "deg",
      "description": "Compensates for horizontal mounting angle (yaw).",
      "required": false
